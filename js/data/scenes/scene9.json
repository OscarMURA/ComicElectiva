    "comic-user-bubbles": {
      "e9-p1": [
        {
          "id": "e9-p1-umpk6odr5",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Habitación de Nico · Noche",
          "type": "narration",
          "x": 89.691162109375,
          "y": 11.474609375
        },
        {
          "id": "e9-p1-umpk6pbg8",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Esa noche Nico no quiso dormir todavía. Sacó su cuaderno y empezó a dibujar.",
          "type": "narration",
          "x": 28.25775146484375,
          "y": 24.690755208333336
        },
        {
          "id": "e9-p1-umpk6rcm3",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "No era un dibujo cualquiera. Era un mapa. Pero el mapa no tenía calles. Tenía hilos.",
          "type": "narration",
          "x": 27.41851806640625,
          "y": 36.44205729166667
        },
        {
          "id": "e9-p1-umpk6rydn",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Una gota… un río… un canal… un cultivo… una galería… un plato… una boca.",
          "type": "narration",
          "x": 26.1749267578125,
          "y": 48.1201171875
        },
        {
          "id": "e9-p1-umpk6sgz3",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Y al final del mapa, me dibujó a mí. Porque sin mí, nadie hubiera olido el camino.",
          "type": "narration",
          "x": 26.28173828125,
          "y": 60.6689453125
        }
      ],
      "e9-p2": [
        {
          "id": "e9-p2-umpk71i8b",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Esa noche Nico durmió con el cuaderno en los brazos.",
          "type": "narration",
          "x": 18.21441650390625,
          "y": 68.27256944444444
        },
        {
          "id": "e9-p2-umpk72iw7",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Mañana seguimos, Bongo. El mundo tiene muchos hilos sueltos.",
          "type": "speech",
          "x": 45.55206298828125,
          "y": 18.70659722222222
        },
        {
          "id": "e9-p2-umpk73tpc",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Y afuera, en el patio, la luna se reflejó en un balde de agua clara.",
          "type": "narration",
          "x": 21.75140380859375,
          "y": 79.27517361111111
        },
        {
          "id": "e9-p2-umpk772pu",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Y yo moví la cola otra vez. Porque sí. Porque mañana seguimos.",
          "type": "narration",
          "x": 22.61199951171875,
          "y": 90.14214409722221
        },
        {
          "id": "e9-p2-umpk78x6k",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Guau...",
          "type": "speech",
          "x": 40.42205810546875,
          "y": 51.47026909722222
        }
      ]
    },
