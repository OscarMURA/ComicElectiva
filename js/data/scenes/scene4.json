    "comic-user-bubbles": {
      "e4-p1": [
        {
          "id": "e4-p1-umpk4qotj",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Galería Alameda · 1:00 PM",
          "type": "narration",
          "x": 10.09521484375,
          "y": 92.09255642361111
        },
        {
          "id": "e4-p1-umpk4wa6c",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Mi nariz se volvió loca. Olía a fiesta. Olía a cumpleaños. Olía a que aquí podrían comer mil perros, mil niños, mil abuelos.",
          "type": "narration",
          "x": 51.6021728515625,
          "y": 11.688910590277777
        },
        {
          "id": "e4-p1-umpk4y2s8",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Pero nadie comía. La comida lloraba sola tirada en el suelo.",
          "type": "thought",
          "x": 21.92840576171875,
          "y": 53.33116319444444
        },
        {
          "id": "e4-p1-umpk56rcz",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Bongo... pero si todas estas frutas están buenas. ¿Por qué las tiraron?",
          "type": "speech",
          "x": 80.084228515625,
          "y": 75.830078125
        }
      ],
      "e4-p2": [
        {
          "id": "e4-p2-umpk58za2",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Bongo… mirá.",
          "type": "speech",
          "x": 43.14422607421875,
          "y": 52.64756944444444
        },
        {
          "id": "e4-p2-umpk59khq",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Cada fruta tiene un hilo. Y los hilos van a alguna parte… pero alguien los cortó.",
          "type": "speech",
          "x": 30.206298828125,
          "y": 72.42296006944444
        },
        {
          "id": "e4-p2-umpk5c0xq",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Los humanos creen que la comida nace en las cajas, pero cada fruto tiene un hilo invisible que lo une a la tierra y a la boca de quien lo necesita. Alguien cortó esos hilos... y dejó al mundo a oscuras.",
          "type": "narration",
          "x": 46.441650390625,
          "y": 12.906901041666666
        }
      ]
    },
