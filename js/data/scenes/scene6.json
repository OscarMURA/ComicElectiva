      ],
      "e6-p2": [
        {
          "id": "e6-p2-umpkxzol6",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "¡Yo te oigo! ¡No estás sola!",
          "type": "speech",
          "x": 86.70166015625,
          "y": 45.73784722222222
        },
        {
          "id": "e6-p2-umpky9qoe",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Aquí empieza todo. La gran guardiana de agua está enferma. Su cuerpo rechaza la contaminación que la invade.",
          "type": "narration",
          "x": 39.43359375,
          "y": 6.727430555555555
        }
      ],
      "e6-p3": [
        {
          "id": "e6-p3-umpkybb3x",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Niño…",
          "type": "speech",
          "x": 41.739501953125,
          "y": 15.010850694444445
        },
        {
          "id": "e6-p3-umpkye24y",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Cada cosa que botan a mí… sale de la boca de alguien hambriento.",
          "type": "speech",
          "x": 75.592041015625,
          "y": 17.936197916666664
        },
        {
          "id": "e6-p3-umpkyfa20",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Cada cosa que limpian de mí… llena un plato.",
          "type": "speech",
          "x": 23.763427734375,
          "y": 26.091579861111114
        },
        {
          "id": "e6-p3-umpkyfw1v",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "¿Entendés ahora… por qué el agua y el hambre son la misma HISTORIA?",
