      "e2-p1": [
        {
          "id": "e2-p1-umpjclwed",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Wooooh, whoooh...",
          "type": "speech",
          "x": 58.9630126953125,
          "y": 20.128038194444446
        },
        {
          "id": "e2-p1-umpjcxl48",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Guau Guau :D",
          "type": "speech",
          "x": 35.406494140625,
          "y": 28.968641493055557
        },
        {
          "id": "e2-p1-umpjd81ut",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "¿Qué aventura nos esperará?",
          "type": "speech",
          "x": 80.3741455078125,
          "y": 17.222764756944446
        },
        {
          "id": "e2-p1-ucmpjd8uxx",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Nico extendió la mano… y la gota nos invitó a entrar.",
          "type": "narration",
          "width": 80,
          "x": 23.43994140625,
          "y": 7.879774305555555
        }
      ],
      "e2-p2": [
        {
          "id": "e2-p2-ucmpjcyngn",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Y entonces… volamos",
          "type": "narration",
          "width": 80,
          "x": 50.350341796875,
          "y": 7.549913194444445
        },
        {
          "id": "e2-p2-ucmpjd0452",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "No hacia adelante. Hacia adentro.\nAl alrededor flotaban recuerdos:\nuna abuela lavando ropa en un río limpio,\nun niño bebiendo de una totuma,\nuna nube reventando sobre los Farallones,\nun pez plateado saltando.",
          "type": "narration",
          "width": 80,
          "x": 48.2391357421875,
          "y": 91.24348958333334
        },
        {
          "id": "e2-p2-umpjd2eiz",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Lo entiendo, el agua se acuerda de todo.",
          "type": "thought",
          "x": 59.942626953125,
          "y": 36.8896484375
        },
        {
          "id": "e2-p2-umpjd4f75",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Bongo, Cada gota… tiene memoria de dónde estuvo.",
          "type": "speech",
          "x": 18.42803955078125,
          "y": 25.80837673611111
        },
        {
          "id": "e2-p2-umpjd5x2n",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Guau Guau",
          "type": "speech",
          "x": 47.76763916015625,
          "y": 68.46245659722221
        }
      ],
      "e2-p3": [
        {
          "id": "e2-p3-umpjde8vr",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Bongo, ¿sabes dónde caímos?",
          "type": "speech",
          "x": 25.9521484375,
          "y": 42.33127170138889
        },
        {
          "id": "e2-p3-umpjdff2l",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Uy, ni yo sé...",
          "type": "thought",
          "x": 77.47802734375,
          "y": 60.37055121527778
        },
        {
          "id": "e2-p3-ucmpjdytg7",
          "position": "bottom-center",
          "speaker": "narrator",
          "text": "Aterrizamos suavemente. Como si la gota nos hubiera dejado allí… para que vieramos algo.",
          "type": "narration",
          "width": 80,
          "x": 50.03509521484375,
          "y": 9.22580295138889
        },
        {
          "id": "e2-p3-umpk38qjp",
          "position": "bottom-left",
          "speaker": "narrator",
          "text": "Guau Guau :0",
          "type": "speech",
          "x": 60.18829345703125,
          "y": 85.88053385416666
        }
      ]
